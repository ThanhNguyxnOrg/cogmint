# Anthropic-compatible endpoint (optional)
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# COGMINT runtime paths
# Path to Claude configuration directory used by the app
CLAUDE_DIR=

# Optional explicit path to Claude CLI binary
# Example (Windows): C:\\Users\\you\\AppData\\Roaming\\npm\\claude.cmd
# Example (macOS/Linux): /usr/local/bin/claude
CLAUDE_CLI_PATH=
